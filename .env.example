# Application
APP_NAME=Loviary-Backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_HOST=0.0.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=loviary
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-min-256-bits
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h
JWT_ISSUER=loviary.app
JWT_AUDIENCE=loviary.app

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# File Storage (R2/S3)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=

# Push Notifications (FCM)
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# Feature Flags
FEATURE_MOOD_TRACKING=true
FEATURE_MEMORIES=true
FEATURE_DAILY_SPARKS=true
FEATURE_PROMISES=true
FEATURE_LOVE_GOALS=true
FEATURE_TIME_CAPSULES=true
